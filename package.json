{
  "name": "pedi-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test --project=chromium-headless-shell -c tests/e2e/playwright.config.ts",
    "test:e2e:seed": "tsx tests/e2e/scripts/seed.ts",
    "test:e2e:cleanup": "tsx tests/e2e/scripts/cleanup.ts",
    "test:e2e:all": "playwright test -c tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui -c tests/e2e/playwright.config.ts",
    "test:e2e:smoke": "playwright test --project=chromium-headless-shell -c tests/e2e/playwright.config.ts --grep \"@smoke|@critical\"",
    "test:e2e:critical": "playwright test --project=chromium-headless-shell -c tests/e2e/playwright.config.ts --grep \"@critical\"",
    "test:e2e:fast": "playwright test --project=chromium-headless-shell -c tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow|@webhook\"",
    "test:e2e:shard:auth": "playwright test --project=chromium-headless-shell -c tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow\" tests/e2e/tests/auth/ tests/e2e/tests/customer/register*.spec.ts",
    "test:e2e:shard:customer": "playwright test --project=chromium-headless-shell -c tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow\" tests/e2e/tests/customer/*.spec.ts",
    "test:e2e:shard:admin": "playwright test --project=chromium-headless-shell -c tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow\" tests/e2e/tests/admin/*.spec.ts",
    "test:all": "vitest run tests/unit tests/integration && playwright test --project=chromium-headless -c tests/e2e/playwright.config.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "mailpit": "mailpit",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "prepare": "husky",
    "gstack:review": "node scripts/gstack/review.js",
    "gstack:qa": "node scripts/gstack/qa.js",
    "gstack:ship": "node scripts/gstack/ship.js",
    "gstack:office-hours": "node scripts/gstack/office-hours.js",
    "gstack:progress": "node scripts/generate-progress-report.js",
    "db:seed": "tsx scripts/seed-dev-db.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-query": "^5.100.9",
    "better-sqlite3": "^12.10.0",
    "dexie": "^4.4.2",
    "drizzle-orm": "^0.45.2",
    "immer": "^11.1.7",
    "lucide-react": "^1.14.0",
    "mercadopago": "^2.12.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "stripe": "^22.1.1",
    "workbox-background-sync": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,scss}": [
      "prettier --write"
    ]
  }
}
