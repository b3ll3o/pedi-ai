{
  "name": "pedi-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @pedi-ai/web -- dev",
    "build": "pnpm --filter @pedi-ai/web -- build",
    "start": "pnpm --filter @pedi-ai/web -- start",
    "lint": "pnpm --filter @pedi-ai/web -- lint && pnpm --filter @pedi-ai/api -- lint",
    "lint:api": "pnpm --filter @pedi-ai/api -- lint",
    "lint:web": "pnpm --filter @pedi-ai/web -- lint",
    "test": "vitest",
    "test:unit": "vitest run apps/web/tests/unit",
    "test:integration": "vitest run apps/web/tests/integration",
    "test:e2e": "playwright test --project=chromium-headless-shell -c apps/web/tests/e2e/playwright.config.ts",
    "test:e2e:seed": "tsx apps/web/tests/e2e/scripts/seed.ts",
    "test:e2e:cleanup": "tsx apps/web/tests/e2e/scripts/cleanup.ts",
    "test:e2e:all": "playwright test -c apps/web/tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui -c apps/web/tests/e2e/playwright.config.ts",
    "test:e2e:smoke": "playwright test --project=chromium-headless-shell -c apps/web/tests/e2e/playwright.config.ts --grep \"@smoke|@critical\"",
    "test:e2e:critical": "playwright test --project=chromium-headless-shell -c apps/web/tests/e2e/playwright.config.ts --grep \"@critical\"",
    "test:e2e:fast": "playwright test --project=chromium-headless-shell -c apps/web/tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow|@webhook\"",
    "test:e2e:shard:auth": "playwright test --project=chromium-headless-shell -c apps/web/tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow\" apps/web/tests/e2e/tests/auth/ apps/web/tests/e2e/tests/customer/register*.spec.ts",
    "test:e2e:shard:customer": "playwright test --project=chromium-headless-shell -c apps/web/tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow\" apps/web/tests/e2e/tests/customer/*.spec.ts",
    "test:e2e:shard:admin": "playwright test --project=chromium-headless-shell -c apps/web/tests/e2e/playwright.config.ts --grep \"@critical|@smoke\" --grep-invert \"@slow\" apps/web/tests/e2e/tests/admin/*.spec.ts",
    "test:all": "vitest run apps/web/tests/unit apps/web/tests/integration && playwright test --project=chromium-headless -c apps/web/tests/e2e/playwright.config.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "rtm": "tsx scripts/rtm.ts",
    "mailpit": "mailpit",
    "prepare": "husky",
    "db:seed": "tsx scripts/seed-dev-db.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "ts-pattern": "^5.9.0",
    "tsx": "^4.22.3",
    "typescript": "^6",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "ws": ">=8.20.1",
      "brace-expansion": ">=5.0.6",
      "uuid": ">=11.0.0",
      "minimatch": ">=10.0.3",
      "cross-spawn": ">=7.0.6",
      "js-yaml": ">=4.2.0",
      "vite": "^8.0.16",
      "esbuild": ">=0.28.1",
      "@babel/core": ">=7.29.1",
      "ioredis": "^5.10.1",
      "@opentelemetry/sdk-trace-base": "^1.28.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,scss}": [
      "prettier --write"
    ]
  }
}
