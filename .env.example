# ============================================================
# Pedi-AI — Variáveis de Ambiente
# Use para desenvolvimento local ou deploy Docker/VPS
# Copie para .env na raiz do projeto
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=sua-senha-forte-aqui

# ── JWT (Gere com: openssl rand -hex 32) ────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── API ─────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://0.0.0.0:3000

# ── Web (Next.js) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://user:password@localhost:5432/pedi_ai

# ── SMTP (Mailpit dev) ───────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ── Mercado Pago (opcional) ──────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_DEMO_PAYMENT_MODE=false
MP_WEBHOOK_URL=

# ── Feature Flags ────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_OFFLINE_ENABLED=true
NEXT_PUBLIC_FEATURE_PIX_ENABLED=true
NEXT_PUBLIC_FEATURE_QR_CODE_ENABLED=true
NEXT_PUBLIC_FEATURE_COMBOS_ENABLED=true
NEXT_PUBLIC_ENABLE_MULTI_RESTAURANT=false