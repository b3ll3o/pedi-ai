# pnpm
data/
false/
package-lock.json
.pnpm-store/

# Workspace node_modules
/apps/*/node_modules
/packages/*/node_modules
apps/api/node_modules
apps/web/node_modules
packages/shared/node_modules

# Build outputs
apps/web/.next
apps/web/out
apps/api/dist
packages/shared/dist

# MCP config (contains secrets)
.mcp.json

# OS
Thumbs.db

# Environment files (CRITICAL — never commit secrets)
# ──────────────────────────────────────────────────────
# Block all env files by default. Whitelist explicitly with `!` if needed.
.env
.env.*
!.env.example
!.env.*.example
apps/api/.env
apps/api/.env.*
apps/web/.env
apps/web/.env.*
apps/web/tests/e2e/.env.e2e
packages/*/.env
packages/*/.env.*

# Local config with potential secrets
*.local
config/local.json