{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "ESNext"],
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "ES2015",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
