{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "ESNext"],
    "strict": true,
    "declaration": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
