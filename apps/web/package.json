{
  "name": "@pedi-ai/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "bundle:size": "node scripts/bundle-size.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:worker": "playwright test --workers=1",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:grep": "playwright test -g",
    "test:e2e:smoke": "playwright test --grep=@smoke",
    "test:e2e:critical": "playwright test --grep=@critical",
    "test:e2e:slow": "playwright test --grep=@slow",
    "test:e2e:fast": "playwright test --grepInvert=@slow",
    "test:e2e:seed": "npx tsx tests/e2e/scripts/seed.ts",
    "test:e2e:cleanup": "npx tsx tests/e2e/scripts/cleanup.ts",
    "test:e2e:install-browsers": "playwright install --with-deps chromium firefox webkit",
    "test:e2e:codegen": "playwright codegen"
  },
  "dependencies": {
    "@pedi-ai/feature-flags": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "dexie": "^4.4.4",
    "immer": "^11.1.9",
    "lucide-react": "^1.23.0",
    "mercadopago": "^3.2.0",
    "next": "16.2.9",
    "pdfkit": "^0.19.1",
    "pngjs": "^7.0.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.1",
    "socket.io-client": "^4.8.3",
    "workbox-background-sync": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/pdfkit": "^0.17.6",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
