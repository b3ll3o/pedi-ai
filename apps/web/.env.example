# ── Database ────────────────────────────────────────────────────────────────
# Connection string for PostgreSQL (same database used by apps/api)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CDN de imagens ───────────────────────────────────────────────────────────
# URL completa do CDN que serve as imagens de produto (S3/CloudFront/etc.).
# Sem esta env, `next/image` recusa URLs externas e mostra erro explícito.
# Aceita múltiplas URLs separadas por vírgula para CDN primário + fallback.
# NEXT_PUBLIC_CDN_URL=https://cdn.exemplo.com

# Hostnames extras permitidos em `next/image` (separados por vírgula).
# Útil quando o backend retorna URLs de origens diferentes do CDN principal.
# NEXT_PUBLIC_IMAGE_HOSTNAMES=images.exemplo.com,static.exemplo.com

# ── Server-only Secrets (NUNCA usar NEXT_PUBLIC_ em segredos) ───────────────
# Chave HMAC-SHA256 usada para assinar e validar QR codes de mesa.
# Lida apenas em código server-side (apps/web/src/app/api/tables/validate,
# apps/api/src/tables/*). NUNCA vaza para o bundle do cliente.
QR_SECRET_KEY=troque-por-um-segredo-forte-de-pelo-menos-32-caracteres

# ── Stripe (opcional — apenas se usar pagamentos com Stripe) ─────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
