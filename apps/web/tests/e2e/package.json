{
  "name": "@pedi-ai/e2e",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:worker": "playwright test --workers=1",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:grep": "playwright test -g",
    "test:e2e:smoke": "playwright test --grep=@smoke",
    "test:e2e:critical": "playwright test --grep=@critical",
    "test:e2e:slow": "playwright test --grep=@slow",
    "test:e2e:fast": "playwright test --grepInvert=@slow",
    "clean": "playwright clean",
    "install:browsers": "playwright install --with-deps chromium firefox webkit",
    "codegen": "playwright codegen"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@supabase/supabase-js": "^2.103.3",
    "@types/node": "^22"
  }
}
