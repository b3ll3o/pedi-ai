# Ambiente E2E - Variáveis de ambiente
# Copie este arquivo para .env.e2e e preencha os valores

# ============================================
# Supabase (obrigatório)
# ============================================

# URL do projeto Supabase (formato: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima ( pública - usada pelo cliente browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (privada - usada apenas em scripts de backend/testes E2E)
# NUNCA exponha esta chave no cliente browser!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Opcional
# ============================================

# URL base da aplicação (default: http://localhost:3000)
# BASE_URL=http://localhost:3000
