# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pedi_ai

# Auth JWT — gere valores reais antes de subir a aplicação:
#   openssl rand -hex 32
# O validador de boot (auth/secret-strength.ts) recusa placeholders
# ("your-super-secret-...") e exige ≥32 chars em produção.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# MercadoPago (opcional)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
