// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────

enum OrderStatus {
  pending_payment
  paid
  preparing
  ready
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  credit_card
  debit_card
  pix
  other
}

enum PaymentStatus {
  pending
  paid
  refunded
  failed
}

enum UserRole {
  dono
  gerente
  atendente
  cliente
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  expired
}

// ── Tables ─────────────────────────────────────────────────────

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  slug        String?
  description String?
  address     String?
  phone       String?
  logoUrl     String?
  active      Boolean  @default(true)
  settings    String?  // JSON as string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tables         Table[]
  categories     Category[]
  usersProfiles  UsersProfile[]
  orders         Order[]
  paymentIntents PaymentIntent[]
  subscriptions  Subscription[]
  modifierGroups ModifierGroup[]
  combos         Combo[]

  // Auditoria ACHADO-N4 (Re-varredura 8): `slug` era String? sem
  // @unique/@@index. Rota pública /restaurants/slug/:slug fazia
  // findFirst em todos os restaurants a cada GET de cardápio.
  // Com 1000+ tenants, latência degradava linearmente (sequential scan).
  // @@index (não @unique) preserva slugs duplicados entre tenants
  // diferentes — escopo da unicidade é opcional.
  @@index([slug])
}

model Table {
  id           String    @id @default(uuid())
  restaurantId String
  number       Int
  qrCode       String?
  name         String?
  capacity     Int?
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Restrict: impede deletar Restaurant se houver Tables. Garante que
  // dados de mesas (histórico de pedidos, QR codes) não sejam perdidos
  // acidentalmente. Para "deletar" um restaurante, use soft-delete ou
  // cascade explícito após migrar Orders/PaymentIntents.
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  orders     Order[]

  @@index([restaurantId])
}

model Category {
  id           String    @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  imageUrl     String?
  sortOrder    Int       @default(0)
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  products   Product[]

  @@index([restaurantId])
}

model Product {
  id           String    @id @default(uuid())
  categoryId   String
  name         String
  description  String?
  imageUrl     String?
  price        Float
  dietaryLabels String?
  available    Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category              Category               @relation(fields: [categoryId], references: [id])
  orderItems            OrderItem[]
  comboItems            ComboItem[]
  productModifierGroups ProductModifierGroup[]

  @@index([categoryId])
}

model ModifierGroup {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  required     Boolean  @default(false)
  minSelections Int     @default(0)
  maxSelections Int     @default(1)
  createdAt    DateTime @default(now())

  restaurant         Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  modifierValues     ModifierValue[]
  productModifierGroups ProductModifierGroup[]

  @@index([restaurantId])
}

model ModifierValue {
  id             String   @id @default(uuid())
  modifierGroupId String
  name           String
  priceAdjustment Float   @default(0)
  available      Boolean  @default(true)
  createdAt      DateTime @default(now())

  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Restrict)

  @@index([modifierGroupId])
}

model Combo {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  bundlePrice  Float
  imageUrl     String?
  available    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  comboItems ComboItem[]
  orderItems OrderItem[]

  @@index([restaurantId])
}

model ComboItem {
  id        String   @id @default(uuid())
  comboId   String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  combo   Combo   @relation(fields: [comboId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([comboId])
  @@index([productId])
}

// Auditoria A-AD-05: dedupe atômico via tabela dedicada com unique composto.
// O fluxo é:
//   1. INSERT IdempotencyKey { scope, key } — se P2002, dedupe disparou.
//   2. INSERT Order (operação original).
//   3. Se Order falhar, DELETE IdempotencyKey para permitir retry.
// Sem unique composto, `findFirst` antes do `create` sofre race condition
// (TOCTOU). Esta tabela resolve a nível de DB.
model IdempotencyKey {
  id          String   @id @default(uuid())
  scope       String   // ex: "order:create", "payment:create"
  key         String   // valor do header Idempotency-Key do cliente
  resultHash  String?  // hash do response para retornar mesma resposta
  createdAt   DateTime @default(now())
  expiresAt   DateTime // TTL: 24h (cleanup via job/cron)

  @@unique([scope, key])
  @@index([expiresAt])
}

model Order {
  id              String        @id @default(uuid())
  restaurantId    String
  tableId         String?
  customerId      String?
  customerPhone   String?
  customerName    String?
  customerEmail  String?
  status          OrderStatus    @default(pending_payment)
  // Auditoria ACHADO-6 (Re-varredura 5): optimistic locking para evitar
  // TOCTOU entre webhook do Mercado Pago e mudanças de status por staff.
  // Sem version, um webhook "paid" que chega ao mesmo tempo que um staff
  // que clica em "cancelled" pode fazer last-write-wins silencioso.
  // O `update`/`updateMany` deve incluir `where: { id, version }` e
  // incrementar `version` na mesma operação. Conflito → 409.
  version         Int            @default(0)
  subtotal        Float
  tax             Float
  total           Float
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus @default(pending)
  idempotencyKey  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  restaurant    Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  table         Table?              @relation(fields: [tableId], references: [id], onDelete: Restrict)
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  paymentIntents PaymentIntent[]

  @@index([restaurantId])
  @@index([tableId])
  @@index([customerId])
  // Auditoria ACHADO-N14 (Re-varredura 8): lookup por `idempotencyKey`
  // acontecia sem índice. Em produção com >100k pedidos, latência do
  // findFirst degradava linearmente (sequential scan). Agora:
  // @@index([restaurantId, idempotencyKey]) — composto porque a chave
  // é única por restaurante (escopo multi-tenant).
  @@index([restaurantId, idempotencyKey])
}

model OrderItem {
  id         String    @id @default(uuid())
  orderId    String
  productId  String?
  comboId    String?
  quantity   Int
  unitPrice  Float
  totalPrice Float
  notes      String?
  createdAt  DateTime  @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // SetNull (não Restrict) ao deletar Product/Combo: preserva histórico de
  // pedidos já pagos. O item aparece com productId=null mas mantém o
  // unitPrice/totalPrice para fins fiscais/auditoria.
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  combo   Combo?   @relation(fields: [comboId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model UsersProfile {
  id            String   @id @default(uuid())
  userId        String?  @unique
  restaurantId  String?
  role          UserRole @default(cliente)
  name          String
  email         String   @unique
  passwordHash  String?
  createdAt     DateTime @default(now())

  // SetNull: se Restaurant for deletado (cenário raro), preserva o
  // perfil do usuário mas desvincula do restaurante. Cascade apagaria
  // também refresh tokens, password resets, etc — perda irreversível.
  restaurant       Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]

  @@index([restaurantId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user UsersProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Refresh tokens com rotação e revogação.
/// Cada refresh emite um novo registro e revoga o anterior (cadeia auditável).
/// Reuso de token revogado → invalida toda a família (detecção de reuso).
model RefreshToken {
  id            String    @id @default(uuid())
  userId        String
  tokenHash     String    @unique
  /// Família de rotação — todos os tokens descendentes compartilham este ID.
  familyId      String
  /// Token que substituiu este na rotação (preenchido após rotação).
  replacedById  String?
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime?

  user UsersProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model PaymentIntent {
  id                  String        @id @default(uuid())
  orderId             String
  restaurantId        String
  amount              Float
  currency            String        @default("BRL")
  status              PaymentStatus @default(pending)
  paymentMethod       String
  mercadoPagoPaymentId String?
  qrCode              String?
  qrCodeBase64        String?
  expiresAt           DateTime?
  createdAt           DateTime      @default(now())

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([restaurantId])
}

model Subscription {
  id                    String             @id @default(uuid())
  restaurantId          String
  status                SubscriptionStatus
  planType              String
  priceCents            Int
  currency              String             @default("BRL")
  trialStartedAt        DateTime
  trialEndsAt           DateTime
  trialDays             Int
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  version               Int                @default(1)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  // HIGH-011 (2ª varredura QA): @@unique garante que cada restaurante tem
  // no máximo 1 Subscription, habilitando `upsert` seguro por `restaurantId`
  // e evitando multi-tenant data leak (N assinaturas por restaurante).
  @@unique([restaurantId])
  @@index([restaurantId])
}

model ProductModifierGroup {
  id             String   @id @default(uuid())
  productId      String
  modifierGroupId String
  createdAt      DateTime @default(now())

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierGroupId])
  @@index([productId])
  @@index([modifierGroupId])
}

model WebhookEvent {
  id           String   @id @default(uuid())
  eventType    String
  processedAt  DateTime @default(now())
}
