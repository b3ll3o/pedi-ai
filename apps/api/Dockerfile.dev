# ============================================================
# NestJS API Dockerfile — Development (hot reload)
# Build context: repo root (.)
# ============================================================

FROM node:20-alpine AS base

RUN npm install -g pnpm@9 && apk add --no-cache postgresql-client

WORKDIR /app

# Copy workspace files
COPY pnpm-workspace.yaml ./
COPY packages ./packages
COPY apps/api ./apps/api

# Install dependencies
RUN pnpm install --no-frozen-lockfile

# Generate Prisma client
RUN cd /app/apps/api && pnpm exec prisma generate

EXPOSE 3001

# Development command with hot reload
CMD ["sh", "-c", "cd /app/apps/api && pnpm exec prisma migrate deploy || pnpm exec prisma db push --accept-data-loss && pnpm start:dev"]