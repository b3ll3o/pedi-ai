# ============================================================
# NestJS API Dockerfile — Development (hot reload)
# Build context: repo root (.)
# ============================================================

FROM node:20-slim AS base

RUN corepack enable && corepack prepare pnpm@9 --activate

# Build tools for native modules (bcrypt, prisma) and curl for healthcheck
RUN apt-get update && apt-get install -y python3 make g++ wget curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy workspace files
COPY pnpm-workspace.yaml ./
COPY packages ./packages
COPY apps/api ./apps/api

# Install dependencies
RUN pnpm install --no-frozen-lockfile

# Generate Prisma client
RUN pnpm exec prisma generate --schema apps/api/prisma/schema.prisma

EXPOSE 3001

# Development command with hot reload
CMD ["sh", "-c", "pnpm exec prisma migrate deploy --schema apps/api/prisma/schema.prisma || pnpm exec prisma db push --accept-data-loss --schema apps/api/prisma/schema.prisma && pnpm start:dev"]