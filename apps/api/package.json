{
  "name": "@pedi-ai/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:bdd": "TS_NODE_PROJECT=./tsconfig.bdd.json TS_NODE_TRANSPILE_ONLY=true cucumber-js",
    "test:bdd:fast": "TS_NODE_PROJECT=./tsconfig.bdd.json TS_NODE_TRANSPILE_ONLY=true cucumber-js --tags 'not @slow and not @load-test'",
    "test:bdd:gerenciar": "TS_NODE_PROJECT=./tsconfig.bdd.json TS_NODE_TRANSPILE_ONLY=true cucumber-js --tags '@gerenciar-flags' test/features/admin/feature-flags/gerenciar-flags.feature",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/static": "^9.1.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.27",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^1.27.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^1.27.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.9.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^5.2.0",
    "ms": "^2.1.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
